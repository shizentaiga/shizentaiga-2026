{
  "compilerOptions": {
    /* 基本設定 */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    /* 厳格な型チェック（堅牢なコードのために必須） */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    
    /* ⚡️ ノイズ抑制: 外部ライブラリや型定義ファイル (.d.ts) のチェックをスキップ */
    "skipLibCheck": true,

    /* モジュール解決と型定義 */
    "types": [
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers",
      "vite/client"
    ],
    "resolveJsonModule": true,
    "allowJs": true,
    "isolatedModules": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "_debug/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.min.js"
  ]
}