{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"], /* ← ここに DOM 関連を追加 */
    "moduleResolution": "Bundler",
    "strict": true,                /* すべての厳格な型チェックオプションを有効化 */
    "noImplicitAny": true,         /* 明示的でない 'any' がある場合にエラーにする */
    "strictNullChecks": true,       /* null/undefined の扱いを厳密にする */    
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "@cloudflare/vitest-pool-workers",
      "vite/client"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ]
}